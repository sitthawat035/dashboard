{
  "manifest_version": 3,
  "name": "OpenClaw Shopee Scraper",
  "version": "1.0.0",
  "description": "ดึงข้อมูลสินค้าจากหน้า Shopee Search → ส่งไป Dashboard",
  "permissions": ["activeTab"],
  "host_permissions": ["http://localhost:5000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://shopee.co.th/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon48.png"
  }
}
